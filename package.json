{
  "name": "ai-terminal",
  "version": "1.0.4",
  "description": "Context-aware AI terminal emulator",
  "main": "main.js",
  "bin": {
    "aiterm": "./server.js"
  },
  "scripts": {
    "start": "electron .",
    "dev": "nodemon server.js",
    "release": "electron-builder --linux --win --publish always",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "postinstall": "electron-builder install-app-deps",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "Priyanshu Naredi <naredipriyanshu29@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/PriyanshuNaredi/ai-terminal.git"
  },
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.naredi.aiterminal",
    "productName": "AI Terminal",
    "publish": {
      "provider": "github"
    },
    "linux": {
      "target": ["AppImage", "deb", "pacman"],
      "category": "Utility"
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools"
    }
  },
  "dependencies": {
    "@langchain/classic": "^1.0.34",
    "@langchain/core": "^1.1.48",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/textsplitters": "^1.0.1",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "langchain": "^1.4.2",
    "node-pty": "^1.1.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.14"
  }
}
